{
    "config_version": 2.1,
    "vrm_id": "YOUR VRM ID",
    "debug_level": "INFO",
    "mqtt_username": "YOUR MQTT SERVER USERNAME",
    "mqtt_password": "YOUR MQTT SERVER PASSWORD",
    "mqtt_server_COM_port": 1883,

    "battery_watch": {
        "cell_voltage_too_high": {
            "threshold": 3.6,
            "level": "critical"
        },
        "cell_voltage_too_low": {
            "threshold": 2.9,
            "level": "critical"
        },
        "pack_voltage_too_low": {
            "threshold": 46,
            "level": "critical"
        },
        "battery_too_hot": {
            "threshold": 35,
            "level": "warning"
        },
        "battery_too_cold": {
            "threshold": 5,
            "level": "warning"
        },
        "SOC_low": {
            "threshold": 5,
            "level": "warning"
        },
        "SOC_high": {
            "threshold": "none",
            "level": "info"
        },
        "current_too_high": {
            "threshold": 50,
            "level": "warning"
        }
    },

    "notifications": {
        "mail": {
            "enabled": 0,
            "to_address": "your.mailaddress@abc.com",
            "smtp_host": "smtp.example.com",
            "smtp_port": 587,
            "smtp_user": "",
            "smtp_password": "",
            "from_address": "essbatt-watchdog@example.com",
            "use_tls": 1,
            "use_ssl": 0,
            "timeout_s": 15
        },
        "telegram": {
            "enabled": 0,
            "bot_token": "YOUR_BOT_TOKEN",
            "chat_id": "YOUR_CHAT_ID",
            "timeout_s": 10
        },
        "pushover": {
            "enabled": 0,
            "api_token": "YOUR_PUSHOVER_APP_TOKEN",
            "user_key": "YOUR_PUSHOVER_USER_KEY",
            "min_severity": "critical",
            "priority_critical": 2,
            "priority_error": 1,
            "priority_warning": 0,
            "priority_info": 0,
            "retry_s": 60,
            "expire_s": 900,
            "sound": "siren",
            "timeout_s": 15
        }
    },

    "script_alive_logging_interval": 86400,
    "watchdog_update_rate": 2.0,
    "keepalive_get_all_topics": 0,
    "controller_heartbeat_topic": "essbatt/controller/heartbeat",
    "essBATT_controller_timeout_detection_duration": 95,
    "victron_CCGX_timeout_detection_duration": 60,
    "send_keep_alive_if_essBATT_controller_is_down": 1,
    "switch_off_multis_if_failure_is_detected": 1,
    "ac_power_set_point_if_failure_is_detected": 5,
    "zero_charge_discharge_limits_if_failure_is_detected": 1
}
